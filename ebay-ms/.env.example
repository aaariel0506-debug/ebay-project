# ============================================================
# eBay MS 环境配置（不提交到 git）
# 复制此文件为 .env，填写真实值
# ============================================================

# ── 环境 ──────────────────────────────────────────────────
ENV=dev
# ENV=prod

# ── eBay API ───────────────────────────────────────────────
# 从 developer.ebay.com 获取
EBAY_APP_ID=YOUR_APP_ID
EBAY_CERT_ID=YOUR_CERT_ID
EBAY_DEV_ID=YOUR_DEV_ID
EBAY_ENV=sandbox
# EBAY_ENV=production

# ── 数据库 ─────────────────────────────────────────────────
DB_DIR=~/.ebay-project/data
DB_NAME=ebay.db

# ── 日志 ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=~/.ebay-project/logs

# ── 备份 ───────────────────────────────────────────────────
BACKUP_DIR=~/.ebay-project/backups
BACKUP_RETENTION_DAYS=7

# ── 安全 ───────────────────────────────────────────────────
# Token 加密密钥（Fernet format: 32 url-safe base64-encoded bytes）
# 生成方法：python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
